# ─── DATABASE ───────────────────────────────────────────────────────────────
# Connection string for Prisma. Must match docker-compose credentials.
DATABASE_URL=postgresql://skillyme:skillyme_secret@localhost:5432/skillyme_cohort2

# ─── DOCKER POSTGRES (used by docker-compose.yml) ───────────────────────────
POSTGRES_USER=skillyme
POSTGRES_PASSWORD=skillyme_secret
POSTGRES_DB=skillyme_cohort2

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_byte_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_byte_random_hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── SMTP / EMAIL ────────────────────────────────────────────────────────────
# For Gmail: enable 2FA and create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Skillyme Africa <no-reply@skillyme.africa>"
ADMIN_EMAIL=admin@skillyme.africa

# ─── APP ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://portal.skillyme.africa
PORT=4000

# ─── PROGRAM ─────────────────────────────────────────────────────────────────
PROGRAM_NAME=Skillyme Africa — Cohort 2: Build Track

# ─── FILE UPLOADS ────────────────────────────────────────────────────────────
# Max file size for profile photos in bytes (default 5MB)
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=uploads
